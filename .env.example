# Obligatoire en local : URL du backend Nest (avec ou sans /api).
VITE_API_URL=http://localhost:3000/api

# Production Netlify — pointer vers Render (ou Koyeb tant que la bascule n’est pas faite) :
# VITE_API_URL=https://ton-service.onrender.com/api
#
# Même origin (API sur le même domaine Netlify) : laisser vide ou
# VITE_API_URL=same
